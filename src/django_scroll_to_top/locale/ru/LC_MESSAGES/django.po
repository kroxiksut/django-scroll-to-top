#: .\admin.py:532
msgid "Publish selected revision"
msgstr "Опубликовать выбранную ревизию"

#: .\admin.py:539
#, python-format
msgid "Skipped %(name)s: assign a profile before publishing."
msgstr "Пропущено %(name)s: назначьте профиль перед публикацией."

