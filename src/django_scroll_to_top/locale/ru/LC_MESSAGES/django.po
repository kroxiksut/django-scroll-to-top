#: .\checks.py:32
msgid "django-scroll-to-top migrations could not be inspected."
msgstr "Не удалось проинспектировать миграции django-scroll-to-top."

#: .\checks.py:35
msgid ""
"Run migrations for django-scroll-to-top before relying on the public "
"template tag."
msgstr ""
"Примените миграции django-scroll-to-top, прежде чем полагаться на публичный "
"template tag."

#: .\checks.py:47
msgid "django-scroll-to-top has unapplied migrations."
msgstr "У django-scroll-to-top есть непримённые миграции."

#: .\checks.py:50
msgid ""
"Run `python manage.py migrate django_scroll_to_top` to make renderer "
"configuration checks reliable."
msgstr ""
"Выполните `python manage.py migrate django_scroll_to_top`, чтобы проверки "
"конфигурации рендерера были надёжными."

#: .\checks.py:62
msgid "django-scroll-to-top CSP mode is not supported."
msgstr "Режим CSP django-scroll-to-top не поддерживается."

#: .\checks.py:65
msgid "Set DJANGO_SCROLL_TO_TOP['CSP_MODE'] to 'external' or 'nonce'."
msgstr "Установите DJANGO_SCROLL_TO_TOP['CSP_MODE'] в 'external' или 'nonce'."

#: .\checks.py:79
msgid "django-scroll-to-top default collision policy is not supported."
msgstr "Политика коллизий по умолчанию django-scroll-to-top не поддерживается."

#: .\checks.py:85
msgid ""
"Set DJANGO_SCROLL_TO_TOP['DEFAULT_COLLISION_POLICY'] to one of 'ignore', "
"'shift', 'fallback_corner', or 'hide'."
msgstr ""
"Установите DJANGO_SCROLL_TO_TOP['DEFAULT_COLLISION_POLICY'] в одно из "
"'ignore', 'shift', 'fallback_corner' или 'hide'."

#: .\checks.py:104
msgid ""
"django-scroll-to-top admin integration is enabled but django.contrib.admin "
"is not installed."
msgstr ""
"Интеграция с админкой django-scroll-to-top включена, но django.contrib.admin "
"не установлен."

#: .\checks.py:110
msgid ""
"Add 'django.contrib.admin' to INSTALLED_APPS or set "
"DJANGO_SCROLL_TO_TOP['ADMIN_ENABLED'] to False."
msgstr ""
"Добавьте 'django.contrib.admin' в INSTALLED_APPS или установите "
"DJANGO_SCROLL_TO_TOP['ADMIN_ENABLED'] в False."

#: .\checks.py:125
msgid ""
"django-scroll-to-top Sites Framework integration is enabled but "
"django.contrib.sites is not installed."
msgstr ""
"Интеграция с Sites Framework django-scroll-to-top включена, но "
"django.contrib.sites не установлен."

#: .\checks.py:131
msgid ""
"Add 'django.contrib.sites' to INSTALLED_APPS or set "
"DJANGO_SCROLL_TO_TOP['SITES_FRAMEWORK_ENABLED'] to False."
msgstr ""
"Добавьте 'django.contrib.sites' в INSTALLED_APPS или установите "
"DJANGO_SCROLL_TO_TOP['SITES_FRAMEWORK_ENABLED'] в False."

#: .\checks.py:152
msgid ""
"django-scroll-to-top stylesheet URLs are not included in the project URLConf."
msgstr ""
"URL-адреса таблицы стилей django-scroll-to-top не включены в URLConf проекта."

#: .\checks.py:158
msgid ""
"Include `django_scroll_to_top.urls` with the `django_scroll_to_top` "
"namespace to support strict CSP without `unsafe-inline`."
msgstr ""
"Подключите `django_scroll_to_top.urls` с пространством имён "
"`django_scroll_to_top` для поддержки строгого CSP без `unsafe-inline`."

#: .\checks.py:180
msgid ""
"django-scroll-to-top admin template overrides may not win because "
"django.contrib.admin is installed earlier."
msgstr ""
"Переопределения admin-шаблонов django-scroll-to-top могут не сработать, так "
"как django.contrib.admin установлен раньше."

#: .\checks.py:186
msgid ""
"Place 'django_scroll_to_top' before 'django.contrib.admin' in INSTALLED_APPS "
"when ADMIN_ENABLED is true."
msgstr ""
"Разместите 'django_scroll_to_top' перед 'django.contrib.admin' в "
"INSTALLED_APPS, когда ADMIN_ENABLED истинно."

#: .\checks.py:252
#, python-format
msgid ""
"django-scroll-to-top profiles reference Site ids that no longer exist: "
"%(ids)s."
msgstr ""
"Профили django-scroll-to-top ссылаются на несуществующие идентификаторы "
"Site: %(ids)s."

#: .\checks.py:259
msgid ""
"Point each profile at an existing Site, clear its Site id to make it the "
"global profile, or delete it."
msgstr ""
"Привяжите каждый профиль к существующему Site, очистите его Site id, чтобы "
"сделать его глобальным, или удалите его."

#: .\checks.py:278
#, python-format
msgid ""
"django-scroll-to-top has enabled profiles without a published revision: "
"%(names)s."
msgstr ""
"У django-scroll-to-top есть включённые профили без опубликованной ревизии: "
"%(names)s."

#: .\checks.py:285
msgid ""
"Publish a revision for each profile or disable it. Until then resolution "
"falls back to the global profile or the built-in defaults."
msgstr ""
"Опубликуйте ревизию для каждого такого профиля или отключите его. До этого "
"разрешение откатывается к глобальному профилю или встроенным значениям по "
"умолчанию."

#: .\checks.py:302
msgid "DJANGO_SCROLL_TO_TOP must be a dict."
msgstr "DJANGO_SCROLL_TO_TOP должен быть словарём."

#: .\checks.py:305
msgid ""
"Define DJANGO_SCROLL_TO_TOP as a dictionary of installation flags, for "
"example {'SITE_ENABLED': True}."
msgstr ""
"Определите DJANGO_SCROLL_TO_TOP как словарь установочных флагов, например "
"{'SITE_ENABLED': True}."

#: .\checks.py:317
#, python-format
msgid "DJANGO_SCROLL_TO_TOP has unknown keys: %(keys)s."
msgstr "DJANGO_SCROLL_TO_TOP содержит неизвестные ключи: %(keys)s."

#: .\checks.py:322
#, python-format
msgid "Remove the unknown keys or check for typos. Known keys are: %(known)s."
msgstr ""
"Удалите неизвестные ключи или проверьте опечатки. Известные ключи: %(known)s."

#: .\checks.py:351
#, python-format
msgid "django-scroll-to-top packaged assets are missing: %(names)s."
msgstr "Отсутствуют упакованные ресурсы django-scroll-to-top: %(names)s."

#: .\checks.py:356
msgid ""
"Reinstall the package; the wheel must ship templates and minified static "
"assets."
msgstr ""
"Переустановите пакет; wheel должен содержать шаблоны и минифицированную "
"статику."

